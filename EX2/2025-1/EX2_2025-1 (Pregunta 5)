#include <iostream>
#include "BibliotecaCola/Cola.h"
#include "BibliotecaCola/funcionesCola.h"
void incolarsh(Cola &cola1, int k);
using namespace std;
int main() {
    Cola cola1;
    construir(cola1);
    ElementoCola elemento;
    int k, ultimoElemento;
    cout<<"Ingresa el elemento de la cola:"<<endl;
    cin>>k;
    cout<<"Ingrese el elemento ultimo de la cola:"<<endl;
    cin>>ultimoElemento;
    for (int i = 1; i <= ultimoElemento; i++) {
        elemento.codigo=i;
        encolar(cola1, elemento);
    }
    incolarsh(cola1, k);
    //se obtiene de manera recursiva, sin embargo puse una serie ordenada tal que en caso no lo sea,
    //solo tiene que cambiar la forma de ingreso, ya que en si ordena para todos
    int i= cola1.inicio->elemento.codigo;
    while (i<=ultimoElemento) {
        elemento.codigo=desencolar(cola1).codigo;
        encolar(cola1, elemento);
        i++;
    }
    imprimir(cola1);
    return 0;
}
void incolarsh(Cola &cola1, int k) {
    if (cola1.inicio->elemento.codigo>k) {
        return;
    }
    ElementoCola elemento;
    elemento.codigo=desencolar(cola1).codigo;
    incolarsh(cola1,k);
    encolar(cola1, elemento);
}


