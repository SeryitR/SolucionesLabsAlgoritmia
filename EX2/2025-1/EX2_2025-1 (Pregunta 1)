int merge(int *arr, int ini, int fin, int T) {
    if (ini>=fin) return ini;
    int medio = (ini+fin)/2;
    if (arr[medio] > T) {
        return merge(arr, medio+1, fin, T);
    }
    if (arr[medio] < T) {
        return merge(arr, ini, medio, T);
    }
} //no se puede detallar mucho, simplemente divido y busco el primero menor mas cercano