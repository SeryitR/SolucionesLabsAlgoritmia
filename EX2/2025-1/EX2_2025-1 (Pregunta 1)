    for (int i = 0; i < densidad; i++) {
        cin>>datoIngresado;
        arr[i]=datoIngresado;
    }
    cout<<"Ingrese T: ";
    cin>>T;

    int carie = merge(arr, 0, densidad-1, T);
    if (arr[carie] < T) {
        cout<<"Primera zona con caries clÃ­nica detectada en la posiciÃ³n "<<carie<<endl;
        cout<<"Densidad registrada: "<<arr[carie];
    } else {
        cout<<"No se detecta caries clÃ­nica.";
    }
    return 0;
